@{
    var publicUrl = ViewData["PublicUrl"] as string;
    var pdfUrl = ViewData["PdfUrl"] as string;
    var documentNumber = ViewData["DocumentNumber"] as string;
    var customerName = ViewData["CustomerName"] as string;
    var phoneNumber = ViewData["PhoneNumber"] as string;
    var now = DateTime.Now.ToString("h:mm tt");
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-success mb-4">
            <div class="card-body p-4 text-center">
                <div class="mb-3">
                    <span class="display-4 text-success">&#10003;</span>
                </div>

                <h2 class="card-title text-success mb-3">Receipt Created Successfully</h2>

                <p class="text-muted mb-1"><strong>Receipt</strong> #@documentNumber</p>
                <p class="text-muted mb-4">for <strong>@customerName</strong></p>

                <div class="alert alert-info">
                    <p class="mb-2 fw-semibold">Public URL</p>
                    <a href="@publicUrl" class="text-break" target="_blank">@publicUrl</a>
                </div>

                <div class="d-grid gap-2">
                    <a href="@publicUrl" class="btn btn-primary" target="_blank">View Receipt</a>
                    <a href="@pdfUrl" class="btn btn-outline-primary" target="_blank">Download PDF</a>
                    <a asp-action="Create" class="btn btn-outline-secondary">Create Another</a>
                </div>
            </div>
        </div>

        <div class="text-center mb-3">
            <small class="text-muted">&#8595; WhatsApp Preview (simulated)</small>
        </div>

        <div class="wa-mockup">
            <div class="wa-header">
                <span>&#9664;</span>
                <div class="wa-header-center">
                    <div class="wa-avatar">&#9993;</div>
                    <div>
                        <div class="fw-semibold" style="font-size:14px;">@phoneNumber</div>
                        <div style="font-size:10px;color:#7f8c8d;">online</div>
                    </div>
                </div>
                <span>&#8942;</span>
            </div>
            <div class="wa-chat">
                <div class="wa-date-divider">Today</div>
                <div class="message received">
                    <div class="message-text">
                        Your receipt #@documentNumber is ready.
                    </div>
                    <div class="message-time">@now</div>
                </div>
                <div class="message sent">
                    <div class="message-text">
                        Great, thanks!
                    </div>
                    <div class="message-time">@now</div>
                    <div class="wa-read-tick">&#10003;&#10003;</div>
                </div>
                <div class="message received">
                    <div class="message-text">
                        Your Receipt is ready.<br><br>
                        DocLink<br>
                        <a href="@publicUrl" target="_blank" style="color:#075e54;text-decoration:underline;">@publicUrl</a>
                    </div>
                    <div class="message-time">@now</div>
                </div>
                <div class="wa-typing">
                    <span></span><span></span><span></span>
                </div>
            </div>
            <div class="wa-inputbar">
                <span>&#128522;</span>
                <span class="input-placeholder">Type a message</span>
                <span>&#9654;</span>
            </div>
        </div>

        <div class="text-center mt-3">
            <small class="text-muted">WhatsApp message would be sent to <strong>@phoneNumber</strong> via Meta Cloud API in production</small>
        </div>
    </div>
</div>

<style>
    .wa-mockup {
        max-width: 360px;
        margin: 0 auto;
        background: #e5ddd5;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,0.3);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .wa-header {
        background: #075e54;
        color: #fff;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 14px;
        font-size: 14px;
    }
    .wa-header-center {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 1;
        margin-left: 10px;
    }
    .wa-avatar {
        width: 36px;
        height: 36px;
        background: #128c7e;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
    }
    .wa-chat {
        padding: 10px 12px;
        min-height: 300px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        background-image: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.05"><circle cx="10" cy="10" r="1" fill="%23ccc"/><circle cx="50" cy="30" r="1" fill="%23ccc"/><circle cx="80" cy="60" r="1" fill="%23ccc"/><circle cx="20" cy="80" r="1" fill="%23ccc"/></svg>');
    }
    .wa-date-divider {
        text-align: center;
        font-size: 11px;
        color: #7f8c8d;
        margin: 6px 0;
        background: rgba(255,255,255,0.7);
        padding: 3px 10px;
        border-radius: 6px;
        align-self: center;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .message {
        max-width: 75%;
        padding: 7px 10px;
        border-radius: 6px;
        font-size: 13px;
        line-height: 1.5;
        position: relative;
        box-shadow: 0 1px 1px rgba(0,0,0,0.08);
    }
    .message.received {
        background: #fff;
        color: #303030;
        align-self: flex-start;
        border-top-left-radius: 2px;
    }
    .message.sent {
        background: #dcf8c6;
        color: #303030;
        align-self: flex-end;
        border-top-right-radius: 2px;
    }
    .message-time {
        font-size: 10px;
        color: #888;
        margin-top: 3px;
        text-align: right;
        display: inline;
    }
    .wa-read-tick {
        color: #34b7f1;
        font-size: 10px;
        display: inline;
        margin-left: 2px;
    }
    .wa-inputbar {
        background: #f0f0f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 14px;
        color: #888;
        font-size: 14px;
    }
    .input-placeholder {
        flex: 1;
        margin: 0 10px;
        background: #fff;
        border-radius: 20px;
        padding: 8px 14px;
        color: #888;
        font-size: 13px;
        border: 1px solid #ddd;
    }
    .wa-typing {
        align-self: flex-start;
        background: #fff;
        border-radius: 16px;
        padding: 10px 14px;
        display: flex;
        gap: 4px;
        box-shadow: 0 1px 1px rgba(0,0,0,0.08);
    }
    .wa-typing span {
        width: 7px;
        height: 7px;
        background: #888;
        border-radius: 50%;
        animation: wa-bounce 1.3s ease-in-out infinite;
    }
    .wa-typing span:nth-child(2) { animation-delay: 0.2s; }
    .wa-typing span:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes wa-bounce {
        0%, 60%, 100% { transform: translateY(0); }
        30% { transform: translateY(-5px); }
    }
</style>
