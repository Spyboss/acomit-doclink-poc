@{
    var publicUrl = ViewData["PublicUrl"] as string;
    var pdfUrl = ViewData["PdfUrl"] as string;
    var documentNumber = ViewData["DocumentNumber"] as string;
    var customerName = ViewData["CustomerName"] as string;
    var phoneNumber = ViewData["PhoneNumber"] as string;
    var now = DateTime.Now.ToString("h:mm tt");
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-success mb-4">
            <div class="card-body p-4 text-center">
                <div class="mb-3">
                    <span class="display-4 text-success">&#10003;</span>
                </div>

                <h2 class="card-title text-success mb-3">Receipt Created Successfully</h2>

                <p class="text-muted mb-1"><strong>Receipt</strong> #@documentNumber</p>
                <p class="text-muted mb-4">for <strong>@customerName</strong></p>

                <div class="alert alert-info">
                    <p class="mb-2 fw-semibold">Public URL</p>
                    <a href="@publicUrl" class="text-break" target="_blank">@publicUrl</a>
                </div>

                <div class="d-grid gap-2">
                    <a href="@publicUrl" class="btn btn-primary" target="_blank">View Receipt</a>
                    <a href="@pdfUrl" class="btn btn-outline-primary" target="_blank">Download PDF</a>
                    <a asp-action="Create" class="btn btn-outline-secondary">Create Another</a>
                </div>
            </div>
        </div>

        <div class="text-center mb-3">
            <small class="text-muted">&#8595; SMS Preview (simulated)</small>
        </div>

        <div class="phone-mockup">
            <div class="phone-notch"></div>
            <div class="phone-statusbar">
                <span>@now</span>
                <span>&#128246; &#9881;</span>
            </div>
            <div class="phone-header">
                <span>&#9664;</span>
                <span class="fw-semibold">@phoneNumber</span>
                <span>&#8942;</span>
            </div>
            <div class="phone-chat">
                <div class="message received">
                    <div class="message-text">
                        Your receipt #@documentNumber is ready.
                    </div>
                    <div class="message-time">@now</div>
                </div>
                <div class="message sent">
                    <div class="message-text">
                        Great, thanks!
                    </div>
                    <div class="message-time">@now</div>
                </div>
                <div class="message received">
                    <div class="message-text">
                        Your Receipt is ready.<br><br>
                        DocLink<br>
                        <a href="@publicUrl" target="_blank" style="color:#fff;text-decoration:underline;">@publicUrl</a>
                    </div>
                    <div class="message-time">@now</div>
                </div>
            </div>
            <div class="phone-inputbar">
                <span>&#128522;</span>
                <span class="input-placeholder">Message</span>
                <span>&#9654;</span>
            </div>
        </div>

        <div class="text-center mt-3">
            <small class="text-muted">SMS would be sent to <strong>@phoneNumber</strong> via Twilio in production</small>
        </div>
    </div>
</div>

<style>
    .phone-mockup {
        max-width: 360px;
        margin: 0 auto;
        background: #1a1a2e;
        border-radius: 36px;
        padding: 14px 10px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.3), 0 0 0 2px #333;
        position: relative;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .phone-notch {
        width: 120px;
        height: 22px;
        background: #1a1a2e;
        border-radius: 0 0 16px 16px;
        margin: -14px auto 0;
        position: relative;
        z-index: 2;
    }
    .phone-notch::after {
        content: '';
        width: 10px;
        height: 10px;
        background: #2a2a4a;
        border-radius: 50%;
        position: absolute;
        top: 6px;
        left: 55px;
    }
    .phone-statusbar {
        display: flex;
        justify-content: space-between;
        padding: 6px 14px 4px;
        color: #aaa;
        font-size: 11px;
        font-weight: 500;
    }
    .phone-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 14px;
        color: #fff;
        font-size: 14px;
        border-bottom: 1px solid #2a2a4a;
    }
    .phone-chat {
        background: #16213e;
        padding: 12px 10px;
        min-height: 280px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .message {
        max-width: 80%;
        padding: 8px 12px;
        border-radius: 16px;
        font-size: 13px;
        line-height: 1.5;
        position: relative;
    }
    .message.received {
        background: #2a2a4a;
        color: #e0e0e0;
        align-self: flex-start;
        border-bottom-left-radius: 4px;
    }
    .message.sent {
        background: #0d6efd;
        color: #fff;
        align-self: flex-end;
        border-bottom-right-radius: 4px;
    }
    .message-time {
        font-size: 10px;
        color: #888;
        margin-top: 4px;
        text-align: right;
    }
    .message.sent .message-time {
        color: rgba(255,255,255,0.6);
    }
    .phone-inputbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 14px;
        color: #888;
        font-size: 14px;
        border-top: 1px solid #2a2a4a;
    }
    .input-placeholder {
        flex: 1;
        margin: 0 10px;
        background: #2a2a4a;
        border-radius: 16px;
        padding: 6px 12px;
        color: #666;
        font-size: 13px;
    }
</style>
