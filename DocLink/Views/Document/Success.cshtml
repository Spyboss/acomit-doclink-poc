@{
    var publicUrl = ViewData["PublicUrl"] as string;
    var pdfUrl = ViewData["PdfUrl"] as string;
    var title = ViewData["Title"] as string;
    var documentNumber = ViewData["DocumentNumber"] as string;
    var customerName = ViewData["CustomerName"] as string;
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-success">
            <div class="card-body p-4 text-center">
                <div class="mb-3">
                    <span class="display-4 text-success">&#10003;</span>
                </div>

                <h2 class="card-title text-success mb-3">Receipt Created Successfully</h2>

                <p class="text-muted mb-1"><strong>@title</strong> #@documentNumber</p>
                <p class="text-muted mb-4">for <strong>@customerName</strong></p>

                <div class="alert alert-info">
                    <p class="mb-2 fw-semibold">Public URL</p>
                    <a href="@publicUrl" class="text-break" target="_blank">@publicUrl</a>
                </div>

                <div class="alert alert-secondary text-start">
                    <p class="mb-2 fw-semibold">SMS Dispatch Log</p>
                    <pre class="mb-0 small">To: @ViewData["PhoneNumber"]
Your @title is ready.

DocLink
@publicUrl</pre>
                </div>

                <div class="d-grid gap-2">
                    <a href="@publicUrl" class="btn btn-primary" target="_blank">View Receipt</a>
                    <a href="@pdfUrl" class="btn btn-outline-primary" target="_blank">Download PDF</a>
                    <a asp-action="Create" class="btn btn-outline-secondary">Create Another</a>
                </div>
            </div>
        </div>
    </div>
</div>
