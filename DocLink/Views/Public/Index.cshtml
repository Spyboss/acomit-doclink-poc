@model PublicDocumentViewModel

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="card shadow-sm receipt-card" id="receipt">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary mb-0" id="companyName"></h2>
                </div>

                <div class="row mb-4">
                    <div class="col-6">
                        <p class="text-muted mb-1">Document</p>
                        <p class="fw-semibold mb-0">@Model.DocumentType</p>
                    </div>
                    <div class="col-6 text-end">
                        <p class="text-muted mb-1">Number</p>
                        <p class="fw-semibold mb-0">#@Model.DocumentNumber</p>
                    </div>
                </div>

                <hr />

                <div class="row mb-4">
                    <div class="col-6">
                        <p class="text-muted mb-1">Customer</p>
                        <p class="fw-semibold mb-0">@Model.CustomerName</p>
                    </div>
                    <div class="col-6 text-end">
                        <p class="text-muted mb-1">Date</p>
                        <p class="fw-semibold mb-0">@Model.Date.ToString("MMMM dd, yyyy")</p>
                    </div>
                </div>

                <hr />

                <div class="row mb-3">
                    <div class="col-12">
                        <table class="table table-borderless">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">Description</th>
                                    <th scope="col" class="text-center">Qty</th>
                                    <th scope="col" class="text-end">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>@Model.DocumentType</td>
                                    <td class="text-center">1</td>
                                    <td class="text-end fw-bold">@Model.Amount.ToString("N2")</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-12 text-end">
                        <h4 class="fw-bold">Total: @Model.Amount.ToString("N2")</h4>
                    </div>
                </div>

                <hr />

                <div class="text-center text-muted small">
                    <p class="mb-0" id="companyFooter"></p>
                    <p>This document was generated electronically.</p>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4 justify-content-center">
            <button class="btn btn-primary" onclick="downloadPdf()">
                Download PDF
            </button>
            <button class="btn btn-outline-primary" onclick="printReceipt()">
                Print
            </button>
            <button class="btn btn-outline-primary" onclick="shareReceipt()">
                Share
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const pdfUrl = '@Url.Action("Pdf", "Public", new { token = Model.PublicToken })';
        const publicUrl = window.location.href;

        function downloadPdf() {
            window.location.href = pdfUrl;
        }

        function printReceipt() {
            window.print();
        }

        function shareReceipt() {
            if (navigator.share) {
                navigator.share({
                    title: 'DocLink Receipt',
                    text: 'View your receipt',
                    url: publicUrl
                }).catch(() => {});
            } else {
                navigator.clipboard.writeText(publicUrl).then(() => {
                    alert('Link copied to clipboard!');
                }).catch(() => {
                    prompt('Copy this link:', publicUrl);
                });
            }
        }
    </script>
}
